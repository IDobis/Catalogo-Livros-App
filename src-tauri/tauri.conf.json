{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Catalogo_Colecoes",
  "version": "0.5.0",
  "identifier": "com.catalogo.livros",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Catálogo de Coleções",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/a32.png",
      "icons/a126.png",
      "icons/a256.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
